# Скопируй в .env.deploy и заполни. Файл .env.deploy не коммитить.
# DEPLOY_HOST=root@IP_ИЛИ_ХОСТ_VDS
# DEPLOY_PATH=/home/atra/app/setki21_src
#
# Публичный URL API для браузера (админка и калькулятор ходят с клиента по этому адресу).
# Если nginx проксирует /api на api:8080 — укажи базовый URL сайта, например:
# NUXT_PUBLIC_API_URL=https://www.setki21.ru
# Если API доступен по порту: NUXT_PUBLIC_API_URL=http://45.10.43.248:8083
# Не задан — скрипт деплоя подставит https://www.setki21.ru
